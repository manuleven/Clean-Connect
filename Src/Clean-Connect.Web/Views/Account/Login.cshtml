@using Clean_Connect.Application.DTO
@model LoginDto

@{
    ViewData["Title"] = "Sign In";
    ViewData["PortalRole"] = "Guest";
    ViewData["BodyClass"] = "auth-page-clean";
}

<section class="cc-page">
    <div class="container">
        <div class="cc-grid cc-grid-2">

            <!-- Left Side -->
            <div class="cc-card">
                <img class="cc-card-img"
                     src="~/monoline/assets/img/team-clean.jfif"
                     alt="Professional cleaning service" />

                <div class="cc-card-body">
                    <h1>Welcome Back</h1>

                    <p class="cc-muted">
                        Sign in to access your Clean Connect account, manage bookings,
                        track service requests, and connect with trusted cleaning professionals.
                    </p>

                    <div class="mt-4">
                        <div class="mb-2">
                            ✓ Trusted & Verified Cleaners
                        </div>

                        <div class="mb-2">
                            ✓ Easy Booking & Service Tracking
                        </div>

                        <div class="mb-2">
                            ✓ Secure Payments & Reliable Support
                        </div>

                        <div>
                            ✓ Professional Home & Office Cleaning
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side -->
            <div class="cc-card cc-card-body">

                <h2 class="mb-4">Sign In</h2>

                <form asp-action="Login" method="post">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="cc-form-grid">

                        <!-- Email -->
                        <div class="cc-field full">
                            <label asp-for="Email"></label>

                            <input asp-for="Email"
                                   class="form-control"
                                   autocomplete="username"
                                   placeholder="Enter your email" />

                            <span asp-validation-for="Email"
                                  class="text-danger"></span>
                        </div>

                        <!-- Password -->
                        <div class="cc-field full">
                            <label asp-for="Password"></label>

                            <div class="input-group">
                                <input asp-for="Password"
                                       type="password"
                                       class="form-control"
                                       id="password"
                                       autocomplete="current-password"
                                       placeholder="Enter your password" />

                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        id="togglePassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>

                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <!-- Remember Me -->
                        <div class="full d-flex justify-content-between align-items-center">

                            <div class="form-check">
                                <input asp-for="RememberMe"
                                       class="form-check-input" />

                                <label asp-for="RememberMe"
                                       class="form-check-label">
                                    Remember Me
                                </label>
                            </div>

                            <a asp-action="ForgotPassword"
                               asp-controller="Account">
                                Forgot Password?
                            </a>

                        </div>

                    </div>

                    <div class="cc-actions mt-4">
                        <button class="btn cc-btn-primary btn-lg w-100"
                                type="submit">
                            Sign In
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <span class="cc-muted">
                            Don't have an account?
                        </span>

                        <a asp-action="Register"
                           asp-controller="Account">
                            Create Account
                        </a>
                    </div>

                </form>

            </div>

        </div>
    </div>
</section>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        const togglePassword = document.getElementById('togglePassword');
        const password = document.getElementById('password');

        togglePassword.addEventListener('click', function () {

            const isPassword = password.type === 'password';

            password.type = isPassword ? 'text' : 'password';

            this.innerHTML = isPassword
                ? '<i class="bi bi-eye-slash"></i>'
                : '<i class="bi bi-eye"></i>';
        });
    </script>
}