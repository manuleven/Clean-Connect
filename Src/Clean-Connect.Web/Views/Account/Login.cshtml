@using Clean_Connect.Application.DTO
@model LoginDto


@{
    ViewData["Title"] = "Account Verified";
    ViewData["PortalRole"] = "Guest";
    ViewData["BodyClass"] = "auth-page-clean";
}

<section class="cc-page">
    <div class="container">
        <div class="cc-grid cc-grid-2">

            <!-- Left Side -->
            <div class="cc-card">
                <img class="cc-card-img"
                     src="~/monoline/assets/img/team-clean.jfif"
                     alt="Professional cleaning service" />

                <div class="cc-card-body">
                    <h1>Welcome Back</h1>

                    <p class="cc-muted">
                        Sign in to access your Clean Connect account, manage bookings,
                        track service requests, and connect with trusted cleaning professionals.
                    </p>

                    <div class="mt-4">
                        <div class="mb-2">
                            ✓ Trusted & Verified Cleaners
                        </div>

                        <div class="mb-2">
                            ✓ Easy Booking & Service Tracking
                        </div>

                        <div class="mb-2">
                            ✓ Secure Payments & Reliable Support
                        </div>

                        <div>
                            ✓ Professional Home & Office Cleaning
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side -->
            <div class="cc-card cc-card-body">
                <div class="alert" data-form-alert hidden></div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <h2 class="mb-4">Sign In</h2>

                    <div class="cc-form-grid">

                        <div class="cc-field full">
                            <label asp-for="Email" placeholder="Enter your email">Email Address</label>
                            <input id="email"
                                   name="email"
                                   type="email"
                                   autocomplete="username"
                                   required />

                            <span asp-validation-for="Email" class="text-danger"></span>
                                Email address is required.
                            </span>
                        </div>

                        <div class="cc-field full">
                            <label asp-for="Password" placeholder="Enter your password">Password</label>
                            <input id="password"
                                   name="password"
                                   type="password"
                                   autocomplete="current-password"
                                   required />

                            <span class="cc-field-error">
                                Password is required.
                            </span>
                        </div>

                        <div class="full d-flex justify-content-between align-items-center">
                            <label asp-for="RememberMe">
                                <input asp-for="RememberMe" name="rememberMe" type="checkbox" />
                                Remember Me
                            </label>

                            <a href="/Forgot-Password">
                                Forgot Password?
                            </a>
                        </div>

                    </div>

                    <div class="cc-actions mt-4">
                        <button class="btn cc-btn-primary btn-lg w-100"
                                type="submit">
                            Sign In
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <span class="cc-muted">
                            Don't have an account?
                        </span>

                        <a asp-controller="Account" asp-action="Register">
                            Create Account
                        </a>
                    </div>

                </form>
            </div>

        </div>
    </div>
</section>