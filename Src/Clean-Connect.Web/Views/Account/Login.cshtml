@{
    ViewData["Title"] = "Sign In";
    ViewData["BodyClass"] = "auth-page";
}

<div class="auth-wrapper">
    <div class="ambient-glow ambient-glow--top-left"></div>
    <div class="ambient-glow ambient-glow--bottom-right"></div>

    <div class="auth-card reveal-lift">
        <div class="auth-card__header">
            <span class="brand-mark" style="margin: 0 auto 1rem; width: 3.5rem; height: 3.5rem; font-size: 1.5rem;">
                @await Html.PartialAsync("_AppIcon", "sparkle")
            </span>
            <h2>Welcome Back</h2>
            <p>Enter your credentials to manage your cleaning dashboard</p>
        </div>

        <div id="login-error" class="coupon-feedback-bubble coupon-feedback-bubble--error" style="margin-bottom: 1.5rem; width: 100%; display: none;">
            @await Html.PartialAsync("_AppIcon", "shield")
            <span id="error-message">Invalid email or password.</span>
        </div>

        <form id="login-form" onsubmit="handleLogin(event)">
            <div class="form-group-clean">
                <label for="email">Email Address</label>
                <input type="email" id="email" class="input-clean" placeholder="e.g. name@example.com" required autocomplete="username" />
            </div>

            <div class="form-group-clean">
                <label for="password">Password</label>
                <input type="password" id="password" class="input-clean" placeholder="••••••••" required autocomplete="current-password" />
            </div>

            <button type="submit" class="btn-clean btn-clean--primary btn-clean--full" style="margin-top: 1.5rem;">
                @await Html.PartialAsync("_AppIcon", "shield")
                <span>Sign In Securely</span>
            </button>
        </form>

        <div class="auth-toggle">
            Don't have an account? <a asp-controller="Account" asp-action="Register">Create Account</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Check if already logged in and redirect to profile
        if (localStorage.getItem("clean_connect_token")) {
            window.location.href = '@Url.Action("Profile", "Account")';
        }

        async function handleLogin(e) {
            e.preventDefault();
            const email = document.getElementById("email").value;
            const password = document.getElementById("password").value;
            const errorBubble = document.getElementById("login-error");
            const errorMessage = document.getElementById("error-message");
            const submitBtn = e.target.querySelector("button[type='submit']");
            const submitBtnText = submitBtn.querySelector("span");

            errorBubble.style.display = "none";
            submitBtn.disabled = true;
            const originalText = submitBtnText.innerText;
            submitBtnText.innerText = "Authenticating...";

            try {
                const response = await fetch("http://localhost:5022/api/v1/Account/Login", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ email, password })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || "Failed to authenticate. Please check your credentials.");
                }

                // If authentication is successful, we store user session details in localStorage
                if (data.token) {
                    localStorage.setItem("clean_connect_token", data.token);
                    localStorage.setItem("clean_connect_user_email", email);
                    localStorage.setItem("clean_connect_user_id", data.userId || "");
                    
                    // Fetch client profile details if they exist to store them
                    try {
                        const clientRes = await fetch("http://localhost:5022/api/Client/all-clients");
                        if (clientRes.ok) {
                            const clients = await clientRes.json();
                            const matchedClient = clients.find(c => c.email && c.email.value && c.email.value.toLowerCase() === email.toLowerCase());
                            if (matchedClient) {
                                localStorage.setItem("clean_connect_client", JSON.stringify(matchedClient));
                            }
                        }
                    } catch (err) {
                        console.error("Could not fetch client record on login:", err);
                    }

                    // Redirect to client profile
                    window.location.href = '@Url.Action("Profile", "Account")';
                } else {
                    throw new Error("Invalid token response from server.");
                }
            } catch (error) {
                console.error("Login error:", error);
                errorMessage.innerText = error.message || "An unexpected error occurred during sign in.";
                errorBubble.style.display = "flex";
                submitBtn.disabled = false;
                submitBtnText.innerText = originalText;
            }
        }
    </script>
}
