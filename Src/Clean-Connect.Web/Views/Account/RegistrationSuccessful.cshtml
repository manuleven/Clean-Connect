@model string
@{
    ViewData["Title"] = "Confirm Your Email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="bi bi-envelope-check-fill text-primary" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="fw-bold text-primary">Almost done!</h2>
                    <p class="text-muted mt-3">
                        We’ve sent a confirmation link to your email:
                        <br />
                        <strong>@Model</strong>
                    </p>
                    <p>
                        Please check your inbox (and spam folder) and click the link
                        to activate your account.
                    </p>

                </div>
            </div>
        </div>
    </div>
</div>
