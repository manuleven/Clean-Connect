@{
    ViewData["Title"] = "Email Confirmed";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="fw-bold text-success">Email Confirmed!</h2>
                    <p class="text-muted mt-3">
                        🎉 Your email has been successfully confirmed.
                        You can now log in to your account and start using the app.
                    </p>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-success btn-lg mt-4 rounded-pill px-4">
                        Go to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
