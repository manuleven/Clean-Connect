@{
    var requestedRole = Context.Request.Query["role"].ToString();

    var defaultRole = string.Equals(requestedRole, "Worker", StringComparison.OrdinalIgnoreCase)
        ? "Worker"
        : "Client";

    ViewData["Title"] = "Create Account";
    ViewData["PortalRole"] = "Guest";
    ViewData["BodyClass"] = "auth-page";
}

<section class="cc-page">
    <div class="container">
        <div class="cc-grid cc-grid-2">

            <div class="cc-card">
                <img class="cc-card-img"
                     src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?auto=format&fit=crop&w=800&q=80"
                     alt="Professional cleaning team smiling" />

                <div class="cc-card-body">
                    <h1>Let’s get you started</h1>

                    <p class="cc-muted">
                        Whether you are here to look after your space or find your next flexible gig, we’ve got you covered. Choose your account type below to begin.
                    </p>

                    <div class="cc-list mt-4">

                        <div class="cc-list-item">
                            <span class="cc-metric-icon cc-tone-green">
                                <i class="fa fa-home"></i>
                            </span>
                            <div>
                                <strong>I want to book a service</strong>
                                <p class="cc-muted mb-0">
                                    Find trusted professionals, schedule cleanings effortlessly, and manage your payments securely in one place.
                                </p>
                            </div>
                        </div>

                        <div class="cc-list-item">
                            <span class="cc-metric-icon cc-tone-blue">
                                <i class="fa fa-briefcase"></i>
                            </span>
                            <div>
                                <strong>I want to earn as a provider</strong>
                                <p class="cc-muted mb-0">
                                    Set your own schedule, claim open cleaning jobs in your area, and watch your earnings grow.
                                </p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="cc-card cc-card-body">

                <div class="alert" data-form-alert hidden></div>

                <form asp-action="Register" method="post">

                    <div class="cc-form-grid">

                        <div class="cc-field full">
                            <label for="role">I am registering as a...</label>
                            <select id="role" name="role" required>
                                <option value="Client" selected="@(defaultRole == "Client")">Client (Looking for cleaning services)</option>
                                <option value="Worker" selected="@(defaultRole == "Worker")">Worker (Looking for cleaning jobs)</option>
                            </select>
                            <span class="cc-field-error">Please choose how you'd like to use the platform.</span>
                        </div>

                        <div class="cc-field full">
                            <label for="email">Email Address</label>
                            <input id="email" name="email" type="email" placeholder="e.g., alex@example.com" autocomplete="email" required />
                            <span class="cc-field-error">Please enter a valid email address.</span>
                        </div>

                        <div class="cc-field full">
                            <label for="password">Password</label>
                            <input id="password" name="password" type="password" placeholder="At least 8 characters" autocomplete="new-password" required />
                            <span class="cc-field-error">Please choose a password.</span>
                        </div>

                    </div>

                    <div class="cc-actions mt-4">
                        <button class="btn cc-btn-primary btn-lg" type="submit">
                            Create my account
                        </button>

                        <a class="btn btn-outline-secondary btn-lg"
                           asp-controller="Account"
                           asp-action="Login">
                            Sign in instead
                        </a>
                    </div>

                </form>

            </div>

        </div>
    </div>
</section>