@{
    ViewData["Title"] = "Email Verification Required";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow border-0">
                <div class="card-body text-center p-5">

                    <div class="mb-4">
                        <i class="fas fa-envelope-circle-check text-primary"
                           style="font-size:70px"></i>
                    </div>

                    <h2 class="fw-bold mb-3">
                        Verify Your Email
                    </h2>

                    <p class="text-muted mb-4">
                        Your email address
                        <strong>@ViewBag.Email</strong>
                        has not been verified.
                    </p>

                    <p class="text-muted">
                        Please check your inbox and spam folder for the verification email.
                        If you didn't receive one, you can request another below.
                    </p>

                    <form asp-action="ResendConfirmationEmail"
                          method="post"
                          class="mt-4">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="email"
                               value="@ViewBag.Email" />

                        <button type="submit"
                                class="btn btn-primary w-100">
                            <i class="fas fa-paper-plane me-2"></i>
                            Resend Verification Email
                        </button>
                    </form>

                    <hr class="my-4" />

                    <a asp-action="Login"
                       class="text-decoration-none">
                        ← Back to Login
                    </a>

                </div>
            </div>

        </div>
    </div>
</div>