@model WorkerPortalViewModel
@{
    ViewData["Title"] = "Workers";
    ViewData["BodyClass"] = "workers-page";
}

<section class="page-hero page-hero--compact">
    <div class="page-shell page-hero__grid">
        <div>
            <p class="eyebrow">Worker operations</p>
            <h1>Onboard cleaners, review availability, and manage job responses.</h1>
            <p>Built around the worker API flows: registration, update, nearby matching, booking accept/reject, and worker booking history.</p>
        </div>
        <ol class="flow-list" aria-label="Worker verification progress">
            @foreach (var step in Model.VerificationSteps)
            {
                @await Html.PartialAsync("_BookingStep", step)
            }
        </ol>
    </div>
</section>

<section class="page-section">
    <div class="page-shell app-workspace ops-workspace">
        <div class="workspace-main">
            <div class="section-heading section-heading--left">
                <p class="eyebrow">Roster</p>
                <h2>Cleaner directory and dispatch status.</h2>
            </div>

            <div class="resource-list">
                @foreach (var worker in Model.Workers)
                {
                    <article class="resource-row">
                        <span class="avatar-token">@worker.Initials</span>
                        <span>
                            <strong>@worker.Name</strong>
                            <small>@worker.ServiceType · @worker.Location</small>
                        </span>
                        <span class="rating-pill">@worker.Rating</span>
                        <span class="status-pill">@worker.Status</span>
                    </article>
                }
            </div>
        </div>

        <aside class="summary-panel">
            <h2>Register worker</h2>
            <div class="form-grid form-grid--single">
                <label class="field-shell">
                    <span>Full name</span>
                    <input type="text" value="Amara Okafor" />
                </label>
                <label class="field-shell">
                    <span>Service type</span>
                    <select>
                        <option>Deep Clean</option>
                        <option>Home Reset</option>
                        <option>Office Shine</option>
                    </select>
                </label>
                <label class="field-shell">
                    <span>Location</span>
                    <input type="text" value="Lekki Phase 1" />
                </label>
                <label class="field-shell">
                    <span>Contact</span>
                    <input type="tel" value="+234 801 000 2211" />
                </label>
            </div>
            <button class="btn-clean btn-clean--primary btn-clean--full" type="button">
                @await Html.PartialAsync("_AppIcon", "user")
                <span>Save worker</span>
            </button>
        </aside>
    </div>
</section>

<section class="page-section page-section--soft">
    <div class="page-shell split-layout">
        <div class="section-heading section-heading--left">
            <p class="eyebrow">Queue</p>
            <h2>Booking response console.</h2>
            <p>Workers can accept, reject, start jobs, and mark completion from a focused action list.</p>
        </div>
        <div class="operations-panel">
            <div class="activity-stack">
                @foreach (var item in Model.BookingQueue)
                {
                    @await Html.PartialAsync("_ActivityItem", item)
                }
            </div>
        </div>
    </div>
</section>
