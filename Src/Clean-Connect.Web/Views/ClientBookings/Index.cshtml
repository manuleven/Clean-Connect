@model ClientBookingFlowViewModel
@{
    ViewData["Title"] = "Book Cleaning";
    ViewData["PortalRole"] = "Client";
}

<section class="cc-app-shell">
    <div class="container">
        <div class="cc-app-header">
            <div>
                <h1>Book a cleaning</h1>
                <p class="cc-muted">Select a service, schedule a time, match a worker, apply a coupon, and prepare escrow payment.</p>
            </div>
            <span class="cc-status success">Client workflow</span>
        </div>

        <div class="cc-grid cc-grid-2">
            <section class="cc-card cc-card-body">
                <h2>Booking details</h2>
                <div class="alert" data-form-alert hidden></div>
                <form data-demo-form data-success="Booking draft created. Continue to payment when the worker accepts." novalidate>
                    <div class="cc-form-grid">
                        <div class="cc-field full">
                            <label for="serviceTypeId">Service</label>
                            <select id="serviceTypeId" name="serviceTypeId" required>
                                @foreach (var service in Model.Services)
                                {
                                    <option value="@service.Id">@service.Name - NGN @service.Amount.ToString("N0")</option>
                                }
                            </select>
                            <span class="cc-field-error">Choose a service.</span>
                        </div>
                        <div class="cc-field">
                            <label for="dateOfService">Date</label>
                            <input id="dateOfService" name="dateOfService" type="date" required />
                            <span class="cc-field-error">Choose a date.</span>
                        </div>
                        <div class="cc-field">
                            <label for="timeRange">Time range</label>
                            <select id="timeRange" name="timeRange" required>
                                <option>Morning</option>
                                <option>Afternoon</option>
                            </select>
                            <span class="cc-field-error">Choose a time range.</span>
                        </div>
                        <div class="cc-field">
                            <label for="latitude">Latitude</label>
                            <input id="latitude" name="latitude" type="number" step="any" value="6.428" min="4" max="14" required />
                            <span class="cc-field-error">Enter a Nigeria latitude.</span>
                        </div>
                        <div class="cc-field">
                            <label for="longitude">Longitude</label>
                            <input id="longitude" name="longitude" type="number" step="any" value="3.421" min="2.5" max="15.5" required />
                            <span class="cc-field-error">Enter a Nigeria longitude.</span>
                        </div>
                        <div class="cc-field">
                            <label for="workerId">Preferred worker</label>
                            <select id="workerId" name="workerId" required>
                                @foreach (var worker in Model.RecommendedWorkers)
                                {
                                    <option value="@worker.Id">@worker.Name - @worker.Rating.ToString("0.00")</option>
                                }
                            </select>
                            <span class="cc-field-error">Choose a worker.</span>
                        </div>
                        <div class="cc-field">
                            <label for="couponCode">Coupon code</label>
                            <input id="couponCode" name="couponCode" value="CLEAN10" />
                            <span class="cc-field-error">Coupon is optional.</span>
                        </div>
                        <div class="cc-field full">
                            <label for="notes">Cleaner instructions</label>
                            <textarea id="notes" rows="4" placeholder="Gate code, pets, rooms, preferred supplies"></textarea>
                        </div>
                    </div>
                    <div class="cc-actions mt-4">
                        <button class="btn cc-btn-primary" type="submit">Create booking draft</button>
                        <a class="btn btn-outline-secondary" asp-controller="ClientPayments" asp-action="Index">Continue to payments</a>
                    </div>
                </form>
            </section>

            <aside class="cc-card cc-card-body">
                <h2>Recommended workers</h2>
                <div class="cc-list">
                    @foreach (var worker in Model.RecommendedWorkers)
                    {
                        <div class="cc-list-item">
                            <img class="cc-avatar" src="@worker.Image" alt="@worker.Name" />
                            <div>
                                <strong>@worker.Name</strong>
                                <p class="cc-muted mb-1">@worker.Service · @worker.Location</p>
                                <span class="cc-status success">@worker.Rating.ToString("0.00") rating</span>
                                <small class="ms-2">@worker.Availability</small>
                            </div>
                        </div>
                    }
                </div>
            </aside>
        </div>

        <section class="cc-card cc-card-body mt-4">
            <h2>Recent booking states</h2>
            <div class="cc-list">
                @foreach (var booking in Model.RecentBookings)
                {
                    <div class="cc-list-item">
                        <span class="cc-metric-icon cc-tone-blue"><i class="fa fa-check-square-o"></i></span>
                        <div class="flex-grow-1">
                            <strong>@booking.Reference · @booking.Service</strong>
                            <p class="cc-muted mb-2">@booking.DateOfService.ToString("MMM dd, yyyy") · @booking.TimeRange · NGN @booking.Amount.ToString("N0")</p>
                            <span class="cc-status">@booking.BookingStatus</span>
                            <span class="cc-status warning ms-2">@booking.PaymentStatus</span>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" type="button" data-action-target="#tracking-state" data-action-state="@booking.BookingStatus">View state</button>
                    </div>
                }
            </div>
            <p class="mt-3 mb-0">Selected tracking state: <span id="tracking-state" class="cc-status">None selected</span></p>
        </section>
    </div>
</section>
