@model ClientDashboardViewModel
@{
    ViewData["Title"] = "Client Dashboard";
    ViewData["PortalRole"] = "Client";
}

<section class="cc-app-shell">
    <div class="container">
        <div class="cc-app-header">
            <div>
                <h1>Welcome back, @Model.User.Name</h1>
                <p class="cc-muted">Track bookings, payment status, cleaner updates, and referral rewards from @Model.User.Location.</p>
            </div>
            <a class="btn cc-btn-primary btn-lg" asp-controller="ClientBookings" asp-action="Index">Book cleaning</a>
        </div>

        <div class="cc-grid cc-grid-3 mb-4">
            @foreach (var metric in Model.Metrics)
            {
                <article class="cc-card cc-card-body cc-metric">
                    <span class="cc-metric-icon cc-tone-@metric.Tone"><i class="fa @metric.Icon"></i></span>
                    <h2 class="mt-3 mb-1">@metric.Value</h2>
                    <strong>@metric.Label</strong>
                    <p class="cc-muted mb-0">@metric.Detail</p>
                </article>
            }
        </div>

        <div class="cc-grid cc-grid-2">
            <section class="cc-card cc-card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="mb-0">Upcoming bookings</h2>
                    <a asp-controller="ClientBookings" asp-action="Index">View all</a>
                </div>
                <div class="cc-list">
                    @foreach (var booking in Model.UpcomingBookings)
                    {
                        <div class="cc-list-item">
                            <span class="cc-metric-icon cc-tone-blue"><i class="fa fa-calendar"></i></span>
                            <div class="flex-grow-1">
                                <strong>@booking.Reference · @booking.Service</strong>
                                <p class="cc-muted mb-2">@booking.WorkerName · @booking.Address</p>
                                <span class="cc-status" id="booking-status-@booking.Reference">@booking.BookingStatus</span>
                                <span class="cc-status warning ms-2">@booking.PaymentStatus</span>
                            </div>
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="ClientBookings" asp-action="Index">@booking.NextAction</a>
                        </div>
                    }
                </div>
            </section>

            <section class="cc-card cc-card-body">
                <h2>Notifications</h2>
                <div class="cc-list">
                    @foreach (var note in Model.Notifications)
                    {
                        <div class="cc-list-item">
                            <span class="cc-metric-icon cc-tone-@(note.Tone == "warning" ? "orange" : note.Tone == "success" ? "green" : "blue")"><i class="fa fa-bell"></i></span>
                            <div>
                                <strong>@note.Title</strong>
                                <p class="cc-muted mb-1">@note.Message</p>
                                <small>@note.Time</small>
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>
    </div>
</section>
