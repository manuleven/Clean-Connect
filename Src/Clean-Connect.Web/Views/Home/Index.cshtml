@model HomePageViewModel
@{
    ViewData["Title"] = "Premium Cleaning Operations";
    ViewData["BodyClass"] = "home-page";
}

<section class="hero-band" style="--hero-image: url('@Url.Content("~/img/cleaning-suite.png")')">
    <div class="hero-band__scrim"></div>
    <div class="page-shell hero-band__content">
        <p class="eyebrow">Cleaning service operating system</p>
        <h1>Clean Connect</h1>
        <p class="hero-copy">Book verified cleaners, protect every payment in escrow, and track the work from dispatch to completion with one calm, polished experience.</p>
        <div class="hero-actions">
            <a class="btn-clean btn-clean--primary btn-clean--large" asp-controller="Booking" asp-action="Index">
                @await Html.PartialAsync("_AppIcon", "calendar")
                <span>Start a booking</span>
            </a>
            <a class="btn-clean btn-clean--ghost btn-clean--large" asp-controller="Tracking" asp-action="Index">
                @await Html.PartialAsync("_AppIcon", "route")
                <span>Track a cleaner</span>
            </a>
        </div>
        <div class="hero-proof" aria-label="Clean Connect service highlights">
            <span>Verified cleaners</span>
            <span>Escrow payments</span>
            <span>Live job tracking</span>
        </div>
    </div>
</section>

<section class="page-section page-section--tight">
    <div class="page-shell metrics-grid">
        @foreach (var metric in Model.Metrics)
        {
            @await Html.PartialAsync("_MetricCard", metric)
        }
    </div>
</section>

<section class="page-section">
    <div class="page-shell section-heading">
        <p class="eyebrow">Service catalog</p>
        <h2>Premium cleaning that feels simple to book and easy to trust.</h2>
        <p>Reusable service cards, consistent tokens, and clear pricing keep the system scalable as your service catalog grows.</p>
    </div>
    <div class="page-shell service-grid">
        @foreach (var service in Model.Services)
        {
            @await Html.PartialAsync("_ServiceCard", service)
        }
    </div>
</section>

<section class="page-section page-section--soft">
    <div class="page-shell split-layout">
        <div class="section-heading section-heading--left">
            <p class="eyebrow">Operations flow</p>
            <h2>Every booking has a visible path from request to payout.</h2>
            <p>Customers see progress. Cleaners see expectations. Admins see bottlenecks before they become support tickets.</p>
            <a class="btn-clean btn-clean--secondary" asp-controller="Admin" asp-action="Index">
                @await Html.PartialAsync("_AppIcon", "chart")
                <span>Open dashboard</span>
            </a>
        </div>
        <div class="operations-panel tilt-card reveal-lift">
            <div class="operations-panel__header">
                <span>Today</span>
                <strong>Live activity</strong>
            </div>
            <div class="activity-stack">
                @foreach (var activity in Model.RecentActivity)
                {
                    @await Html.PartialAsync("_ActivityItem", activity)
                }
            </div>
        </div>
    </div>
</section>
