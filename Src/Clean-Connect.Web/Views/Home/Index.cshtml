@model PublicHomeViewModel
@{
    ViewData["Title"] = "Home";
    ViewData["PortalRole"] = "Guest";
    ViewData["BodyClass"] = "public-home";
}

<section class="cc-hero" style="--cc-hero-image: url('/monoline/assets/img/bg/home-bg.jpg')">
    <div class="container">
        <h1>Clean Connect</h1>
        <p>Book verified cleaners, fund jobs through protected escrow, track every appointment, and manage service quality from one modern cleaning platform.</p>
        <div class="cc-actions mt-4">
            <a class="btn cc-btn-primary btn-lg" asp-controller="Account" asp-action="Register">Book a cleaner</a>
            <a class="btn btn-light btn-lg" asp-controller="Account" asp-action="Register" asp-route-role="Worker">Work with us</a>
        </div>
    </div>
</section>

<section id="services" class="cc-page">
    <div class="container">
        <div class="cc-section-title">
            <h2>Services for homes and workplaces</h2>
            <p>Choose a package, schedule a time, match with a verified worker, and release payment only after the job is confirmed.</p>
        </div>
        <div class="cc-grid cc-grid-3">
            @foreach (var service in Model.Services)
            {
                <article class="cc-card">
                    <img class="cc-card-img" src="@service.Image" alt="@service.Name cleaning service" />
                    <div class="cc-card-body">
                        <h3>@service.Name</h3>
                        <p class="cc-muted">@service.Summary</p>
                        <strong>NGN @service.Amount.ToString("N0")</strong>
                        <span class="cc-status ms-2">@service.Duration</span>
                        <ul class="mt-3">
                            @foreach (var item in service.Includes)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section id="how-it-works" class="cc-band">
    <div class="container">
        <div class="cc-section-title">
            <h2>From request to payout</h2>
            <p>Both sides get a clear workflow: clients see price, progress, and quality; workers see jobs, status, and earnings.</p>
        </div>
        <div class="cc-grid cc-grid-3">
            <div class="cc-card cc-card-body">
                <span class="cc-metric-icon cc-tone-green"><i class="fa fa-calendar-check-o"></i></span>
                <h3 class="mt-3">Schedule</h3>
                <p class="cc-muted">Clients choose service, location, date, and time range using backend-ready booking fields.</p>
            </div>
            <div class="cc-card cc-card-body">
                <span class="cc-metric-icon cc-tone-blue"><i class="fa fa-user-circle"></i></span>
                <h3 class="mt-3">Match</h3>
                <p class="cc-muted">Workers receive nearby requests, accept or reject, and manage job progress from their portal.</p>
            </div>
            <div class="cc-card cc-card-body">
                <span class="cc-metric-icon cc-tone-orange"><i class="fa fa-lock"></i></span>
                <h3 class="mt-3">Protect</h3>
                <p class="cc-muted">Payments move through escrow and payout states, giving both roles confidence in every job.</p>
            </div>
        </div>
    </div>
</section>

<section class="cc-page">
    <div class="container">
        <div class="cc-section-title">
            <h2>Verified workers near you</h2>
            <p>Cleaner profiles, service category, availability, completed jobs, and ratings are visible before a booking is confirmed.</p>
        </div>
        <div class="cc-grid cc-grid-3">
            @foreach (var worker in Model.FeaturedWorkers)
            {
                <article class="cc-card">
                    <img class="cc-card-img" src="@worker.Image" alt="@worker.Name" />
                    <div class="cc-card-body">
                        <h3>@worker.Name</h3>
                        <p class="cc-muted">@worker.Service · @worker.Location</p>
                        <span class="cc-status success">@worker.Rating.ToString("0.00") rating</span>
                        <p class="mt-3 mb-0">@worker.CompletedJobs completed jobs · @worker.Availability</p>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section id="reviews" class="cc-band">
    <div class="container">
        <div class="cc-section-title">
            <h2>People trust the workflow</h2>
            <p>Realistic states for reviews, escrow, notifications, and job completion are represented in the frontend from day one.</p>
        </div>
        <div class="cc-grid cc-grid-3">
            @foreach (var review in Model.Reviews)
            {
                <article class="cc-card cc-card-body">
                    <span class="cc-status success">@review.Rating stars</span>
                    <h3 class="mt-3">@review.Author</h3>
                    <p class="cc-muted">@review.Subject · @review.Date</p>
                    <p>@review.Comment</p>
                </article>
            }
        </div>
    </div>
</section>
