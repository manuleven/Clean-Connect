@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Live Admin Dashboard";
    ViewData["SubTitle"] = "SignalR";
    ViewData["PageDescription"] = "Real-time activity, revenue, bookings, service mix, alerts, and operations actions.";
    ViewData["BodyClass"] = "admin-page";
}

<section class="row gy-4 mb-24" data-admin-dashboard>
    <div class="col-12">
        <div class="cc-hero">
            <div class="cc-hero-inner cc-hero-grid">
                <div>
                    <span class="badge bg-primary-600 text-white radius-8 px-12 py-8 mb-16">Admin command center</span>
                    <h1 class="cc-hero-title mb-16">Real-time cleaning operations with live SignalR updates.</h1>
                    <p class="text-lg mb-0 max-w-720-px">Track revenue, bookings, payouts, support SLA, dispatch activity, and high-priority notifications without leaving the dashboard.</p>
                </div>
                <div class="card bg-white bg-opacity-10 border border-white border-opacity-25 p-20 radius-12">
                    <div class="d-flex align-items-center gap-3">
                        <span class="w-48-px h-48-px rounded-circle bg-success-main d-flex align-items-center justify-content-center text-white">
                            <iconify-icon icon="solar:translation-2-outline" class="text-xxl"></iconify-icon>
                        </span>
                        <div>
                            <span class="d-block text-white fw-semibold" id="adminConnectionStatus">Connecting live feed</span>
                            <small>Falls back to demo updates if the hub is unavailable.</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @foreach (var metric in Model.Metrics)
    {
        <div class="col-xxl-3 col-sm-6">
            @await Html.PartialAsync("_MetricCard", metric)
        </div>
    }
</section>

<section class="row gy-4 mb-24">
    <div class="col-xxl-4">
        <div class="card h-100 radius-12">
            <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="mb-0">Revenue</h6>
                    <span class="text-sm text-secondary-light">Daily capture and escrow funding.</span>
                </div>
                <strong class="text-primary-600">NGN 2.84m</strong>
            </div>
            <div class="card-body p-24">
                <div data-cc-chart="revenue" class="cc-mini-chart"></div>
            </div>
        </div>
    </div>
    <div class="col-xxl-4">
        <div class="card h-100 radius-12">
            <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="mb-0">Bookings</h6>
                    <span class="text-sm text-secondary-light">Weekly active demand.</span>
                </div>
                <strong class="text-success-main">186 active</strong>
            </div>
            <div class="card-body p-24">
                <div data-cc-chart="bookings" class="cc-mini-chart"></div>
            </div>
        </div>
    </div>
    <div class="col-xxl-4">
        <div class="card h-100 radius-12">
            <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="mb-0">Service mix</h6>
                    <span class="text-sm text-secondary-light">Which services are driving load.</span>
                </div>
                <span class="cc-status cc-status--info">Live</span>
            </div>
            <div class="card-body p-24">
                <div data-cc-chart="mix" class="cc-mini-chart"></div>
            </div>
        </div>
    </div>
</section>

<section class="row gy-4">
    <div class="col-xxl-7">
        <div class="card h-100 radius-12">
            <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="mb-0">Live operations</h6>
                    <span class="text-sm text-secondary-light">SignalR activity feed and fallback pulses.</span>
                </div>
                <a asp-controller="Tracking" asp-action="Index" class="text-primary-600 fw-semibold text-sm">Open tracking</a>
            </div>
            <div class="card-body p-24">
                <div class="cc-action-list" id="liveActivityFeed">
                    @foreach (var activity in Model.Activities)
                    {
                        @await Html.PartialAsync("_ActivityItem", activity)
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-xxl-5">
        <div class="card h-100 radius-12">
            <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="mb-0">Admin alerts</h6>
                    <span class="text-sm text-secondary-light">Quality, payout, route, and support alerts.</span>
                </div>
                <span class="cc-status cc-status--warning">Priority</span>
            </div>
            <div class="card-body p-24">
                <div class="d-grid gap-3" id="liveNotifications">
                    @foreach (var notification in Model.Notifications)
                    {
                        <article class="p-16 radius-8 bg-@notification.Tone-50">
                            <strong class="d-block text-primary-light">@notification.Title</strong>
                            <span class="text-sm text-secondary-light">@notification.Message</span>
                            <time class="text-xs text-secondary-light d-block mt-4">@notification.Time</time>
                        </article>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
