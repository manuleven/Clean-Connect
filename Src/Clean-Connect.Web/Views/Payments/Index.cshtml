@model PaymentPageViewModel
@{
    ViewData["Title"] = "Secure Payment";
    ViewData["BodyClass"] = "payment-page";
    var total = Model.Subtotal - Model.Discount + Model.ServiceFee;
}

<section class="page-hero page-hero--compact">
    <div class="page-shell page-hero__grid">
        <div>
            <p class="eyebrow">Protected checkout</p>
            <h1>Pay securely, hold funds in escrow, release after quality approval.</h1>
            <p>A payment experience built around clarity, trust, and fast mobile completion.</p>
        </div>
        <ol class="flow-list" aria-label="Escrow progress">
            @foreach (var step in Model.EscrowSteps)
            {
                @await Html.PartialAsync("_BookingStep", step)
            }
        </ol>
    </div>
</section>

<section class="page-section">
    <div class="page-shell app-workspace payment-workspace" data-payment-page>
        <div class="workspace-main">
            <div class="section-heading section-heading--left">
                <p class="eyebrow">Method</p>
                <h2>Select a payment method.</h2>
            </div>
            <div class="payment-methods">
                @foreach (var method in Model.PaymentMethods)
                {
                    <button class="payment-method @(method.Recommended ? "is-selected" : "")" type="button" data-payment-method aria-pressed="@(method.Recommended ? "true" : "false")">
                        <span class="icon-bubble icon-bubble--@(method.Recommended ? "mint" : "sky")">
                            @await Html.PartialAsync("_AppIcon", method.Icon)
                        </span>
                        <span>
                            <strong>@method.Name</strong>
                            <small>@method.Detail</small>
                        </span>
                        @if (method.Recommended)
                        {
                            <span class="soft-badge">Recommended</span>
                        }
                    </button>
                }
            </div>

            <div class="card-preview tilt-card reveal-lift" aria-label="Payment card preview">
                <div class="card-preview__shine"></div>
                <div class="card-preview__top">
                    <span>Clean Connect</span>
                    @await Html.PartialAsync("_AppIcon", "shield")
                </div>
                <strong>4582  9104  7720  4468</strong>
                <div>
                    <span>Escrow checkout</span>
                    <span>05/29</span>
                </div>
            </div>
        </div>

        <aside class="summary-panel">
            <h2>Booking summary</h2>
            <dl class="summary-list">
                <div>
                    <dt>Premium Deep Clean</dt>
                    <dd>₦@Model.Subtotal.ToString("N0")</dd>
                </div>
                <div>
                    <dt>Coupon CLEAN10</dt>
                    <dd>-₦@Model.Discount.ToString("N0")</dd>
                </div>
                <div>
                    <dt>Protection fee</dt>
                    <dd>₦@Model.ServiceFee.ToString("N0")</dd>
                </div>
            </dl>
            <div class="price-total">
                <span>Total due</span>
                <strong>₦@total.ToString("N0")</strong>
            </div>
            <div class="trust-strip">
                @await Html.PartialAsync("_AppIcon", "shield")
                <span>Funds stay protected until the customer confirms completion.</span>
            </div>
            <a class="btn-clean btn-clean--primary btn-clean--full" asp-controller="Tracking" asp-action="Index">
                @await Html.PartialAsync("_AppIcon", "check")
                <span>Pay and track</span>
            </a>
        </aside>
    </div>
</section>
