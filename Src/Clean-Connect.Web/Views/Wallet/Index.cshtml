@model WalletPortalViewModel
@{
    ViewData["Title"] = "Wallet and Payouts";
    ViewData["BodyClass"] = "wallet-page";
}

<section class="page-hero page-hero--compact">
    <div class="page-shell page-hero__grid">
        <div>
            <p class="eyebrow">Wallet and escrow</p>
            <h1>Track balances, booking escrows, and payout requests.</h1>
            <p>This is the frontend for worker wallets, escrow lookup, and payout initiation across Paystack-backed payment flows.</p>
        </div>
        <ol class="flow-list" aria-label="Payout progress">
            @foreach (var step in Model.PayoutSteps)
            {
                @await Html.PartialAsync("_BookingStep", step)
            }
        </ol>
    </div>
</section>

<section class="page-section page-section--tight">
    <div class="page-shell metrics-grid">
        @foreach (var metric in Model.Metrics)
        {
            @await Html.PartialAsync("_MetricCard", metric)
        }
    </div>
</section>

<section class="page-section">
    <div class="page-shell app-workspace ops-workspace">
        <div class="workspace-main">
            <div class="section-heading section-heading--left">
                <p class="eyebrow">Ledger</p>
                <h2>Escrow and payout movement.</h2>
            </div>
            <div class="resource-list">
                @foreach (var item in Model.Ledger)
                {
                    <article class="ledger-row">
                        <span class="icon-bubble icon-bubble--@item.Tone">
                            @await Html.PartialAsync("_AppIcon", item.Tone == "mint" ? "check" : "card")
                        </span>
                        <span>
                            <strong>@item.Title</strong>
                            <small>@item.Reference · @item.Time</small>
                        </span>
                        <span class="ledger-row__amount">@item.Amount</span>
                        <span class="status-pill">@item.Status</span>
                    </article>
                }
            </div>
        </div>

        <aside class="summary-panel">
            <h2>Request payout</h2>
            <div class="form-grid form-grid--single">
                <label class="field-shell">
                    <span>Booking ID</span>
                    <input type="text" value="CC-48291" />
                </label>
                <label class="field-shell">
                    <span>Account name</span>
                    <input type="text" value="Amara Okafor" />
                </label>
                <label class="field-shell">
                    <span>Account number</span>
                    <input type="text" value="0123456789" />
                </label>
                <label class="field-shell">
                    <span>Bank code</span>
                    <input type="text" value="058" />
                </label>
            </div>
            <button class="btn-clean btn-clean--primary btn-clean--full" type="button">
                @await Html.PartialAsync("_AppIcon", "card")
                <span>Submit payout</span>
            </button>
        </aside>
    </div>
</section>
