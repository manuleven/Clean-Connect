        break;
    case "brush":
        <svg viewBox="0 0 24 24"><path d="M15 4 6 13"/><path d="m14 5 5 5"/><path d="M5 14c-1 1-1 4-1 6 2 0 5 0 6-1l7-7-5-5-7 7Z"/></svg>
        break;
    case "office":
