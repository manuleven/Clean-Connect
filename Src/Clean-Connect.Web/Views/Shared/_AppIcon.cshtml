        break;
    case "check":
        <svg viewBox="0 0 24 24"><path d="m5 12 4 4L19 6"/></svg>
        break;
    default:
        <svg viewBox="0 0 24 24"><path d="M12 3v6M12 15v6M3 12h6M15 12h6"/><path d="m7 7 2 2M15 15l2 2M17 7l-2 2M9 15l-2 2"/></svg>
        break;
}
</span>
