<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <meta name="clean-connect-api-base" content="http://localhost:5022" />
    <title>@ViewData["Title"] - Clean Connect Admin</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />
    
    <!-- WowDash theme stylesheets -->
    <link rel="stylesheet" href="~/monoline/assets/bootstrap/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/remixicon.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/clean-connect-wowdash.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <a class="cc-skip-link" href="#main-content">Skip to content</a>
    
    @await Html.PartialAsync("Partials/_Sidebar")
    
    <main class="dashboard-main">
        @await Html.PartialAsync("Partials/_Navbar")
        
        <div class="dashboard-main-body" id="main-content">
            @await Html.PartialAsync("Partials/_Breadcrumb")
            @RenderBody()
        </div>
        
        @await Html.PartialAsync("Partials/_Footer")
    </main>

    @await Html.PartialAsync("Partials/_Scripts")
    @await RenderSectionAsync("Scripts", required: false)
    @await Component.InvokeAsync("Notyf")
</body>
</html>
