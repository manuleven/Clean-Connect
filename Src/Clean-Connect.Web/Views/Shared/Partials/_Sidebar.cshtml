@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";

    string Active(string controller, string? action = null)
    {
        var controllerMatches = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        var actionMatches = action is null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return controllerMatches && actionMatches ? "active-page" : "";
    }
}

