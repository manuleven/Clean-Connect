<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f766e" />
    <title>@ViewData["Title"] - Clean Connect</title>
    <script>
        (() => {
            const saved = localStorage.getItem("clean-connect-theme");
            const preferred = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
            document.documentElement.dataset.theme = saved || preferred;
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Clean_Connect.Web.styles.css" asp-append-version="true" />
</head>
<body class="@ViewData["BodyClass"]">
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-header">
        <nav class="site-nav page-shell" aria-label="Primary navigation">
            <a class="brand-lockup" asp-controller="Home" asp-action="Index" aria-label="Clean Connect home">
                <span class="brand-mark">
                    @await Html.PartialAsync("_AppIcon", "sparkle")
                </span>
                <span>
                    <strong>Clean Connect</strong>
                    <small>Premium cleaning system</small>
                </span>
            </a>

            <button class="nav-toggle" type="button" data-nav-toggle aria-expanded="false" aria-controls="primary-menu" aria-label="Open navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <div class="site-menu" id="primary-menu" data-nav-menu>
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Booking" asp-action="Index">Booking</a>
                <a asp-controller="Services" asp-action="Index">Services</a>
                <a asp-controller="Workers" asp-action="Index">Workers</a>
                <a asp-controller="Clients" asp-action="Index">Clients</a>
                <a asp-controller="Payments" asp-action="Index">Payment</a>
                <a asp-controller="Tracking" asp-action="Index">Tracking</a>
                <a asp-controller="Wallet" asp-action="Index">Wallet</a>
                <a asp-controller="Coupons" asp-action="Index">Coupons</a>
                <a asp-controller="Admin" asp-action="Index">Admin</a>
            </div>

            <div class="nav-actions">
                <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle dark mode">
                    @await Html.PartialAsync("_AppIcon", "sparkle")
                </button>
                <a class="btn-clean btn-clean--primary" asp-controller="Booking" asp-action="Index">
                    @await Html.PartialAsync("_AppIcon", "calendar")
                    <span>Book now</span>
                </a>
            </div>
        </nav>
    </header>

    <main id="main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="page-shell site-footer__grid">
            <div>
                <a class="brand-lockup brand-lockup--footer" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">
                        @await Html.PartialAsync("_AppIcon", "sparkle")
                    </span>
                    <span>
                        <strong>Clean Connect</strong>
                        <small>Verified cleaners. Protected payments.</small>
                    </span>
                </a>
            </div>
            <div class="footer-links">
                <a asp-controller="Booking" asp-action="Index">Book</a>
                <a asp-controller="Services" asp-action="Index">Services</a>
                <a asp-controller="Workers" asp-action="Index">Workers</a>
                <a asp-controller="Clients" asp-action="Index">Clients</a>
                <a asp-controller="Tracking" asp-action="Index">Track</a>
                <a asp-controller="Wallet" asp-action="Index">Wallet</a>
                <a asp-controller="Admin" asp-action="Index">Dashboard</a>
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
            <p>&copy; 2026 Clean Connect. Built for fast, trustworthy cleaning operations.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
