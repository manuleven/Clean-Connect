@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
    var title = ViewData["Title"] as string ?? "Clean Connect";
    var role = ViewData["PortalRole"] as string ?? "Guest";
    var isClient = string.Equals(role, "Client", StringComparison.OrdinalIgnoreCase);
    var isWorker = string.Equals(role, "Worker", StringComparison.OrdinalIgnoreCase);

    string Active(string name) => string.Equals(controller, name, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0d9488" />
    <meta name="clean-connect-api-base" content="http://localhost:5022" />
    <title>@title - Clean Connect</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />
    <link rel="stylesheet" href="~/monoline/assets/bootstrap/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/monoline/assets/fonts/font-awesome.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/monoline/assets/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/monoline/assets/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/clean-connect-portal.css" asp-append-version="true" />
</head>
<body class="cc-body @ViewData["BodyClass"]" data-portal-role="@role">
    <a class="cc-skip-link" href="#main-content">Skip to content</a>
    <header class="cc-topbar">
        <nav class="container cc-nav" aria-label="Primary navigation">
            <a class="cc-brand" asp-controller="Home" asp-action="Index">
                <span class="cc-brand-mark">CC</span>
                <span>
                    <strong>Clean Connect</strong>
                    <small>Cleaning services platform</small>
                </span>
            </a>
            <button class="cc-menu-toggle" type="button" data-menu-toggle aria-label="Toggle navigation">
                <i class="fa fa-bars"></i>
            </button>
            <div class="cc-nav-links" data-menu>
                @if (isClient)
                {
                    <a class="@Active("ClientDashboard")" asp-controller="ClientDashboard" asp-action="Index">Dashboard</a>
                    <a class="@Active("ClientBookings")" asp-controller="ClientBookings" asp-action="Index">Book</a>
                    <a class="@Active("ClientPayments")" asp-controller="ClientPayments" asp-action="Index">Payments</a>
                    <a class="@Active("ClientMessages")" asp-controller="ClientMessages" asp-action="Index">Messages</a>
                    <a class="@Active("ClientSettings")" asp-controller="ClientSettings" asp-action="Index">Settings</a>
                }
                else if (isWorker)
                {
                    <a class="@Active("WorkerDashboard")" asp-controller="WorkerDashboard" asp-action="Index">Dashboard</a>
                    <a class="@Active("WorkerJobs")" asp-controller="WorkerJobs" asp-action="Index">Jobs</a>
                    <a class="@Active("WorkerWallet")" asp-controller="WorkerWallet" asp-action="Index">Wallet</a>
                    <a class="@Active("WorkerMessages")" asp-controller="WorkerMessages" asp-action="Index">Messages</a>
                    <a class="@Active("WorkerSettings")" asp-controller="WorkerSettings" asp-action="Index">Settings</a>
                }
                else
                {
                    <a href="/#services">Services</a>
                    <a href="/#how-it-works">How it works</a>
                    <a href="/#reviews">Reviews</a>
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                    <a class="cc-nav-cta" asp-controller="Account" asp-action="Register">Get started</a>
                }
            </div>
        </nav>
    </header>

    <main id="main-content">
        @RenderBody()
    </main>

    <footer class="cc-footer">
        <div class="container">
            <div>
                <strong>Clean Connect</strong>
                <p>Verified cleaners, protected payments, clear communication, and cleaner daily operations.</p>
                <p class="mt-2 text-xs text-muted" style="font-size: 0.8rem; color: #64748b; margin-top: 8px;">&copy; @DateTime.Now.Year Clean Connect. All rights reserved.</p>
            </div>
            <div class="cc-footer-links">
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                @if (string.Equals(role, "Guest", StringComparison.OrdinalIgnoreCase))
                {
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                    <a asp-controller="Account" asp-action="Register">Create account</a>
                }
            </div>
        </div>
    </footer>

    <script src="~/monoline/assets/js/jquery-1.12.4.min.js" asp-append-version="true"></script>
    <script src="~/monoline/assets/bootstrap/js/bootstrap.min.js" asp-append-version="true"></script>
    <script src="~/js/clean-connect-portal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @await Component.InvokeAsync("Notyf")
</body>
</html>
