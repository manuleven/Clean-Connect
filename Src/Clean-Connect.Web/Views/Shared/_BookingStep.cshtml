@model BookingStepViewModel

@{
    var stateClass = Model.State switch
    {
        "complete" => "is-complete",
        "active" => "is-active",
        _ => string.Empty
    };
}

<li class="cc-timeline-item @stateClass">
    <span class="cc-timeline-dot"></span>
    <span>
        <strong>@Model.Label</strong>
        <small class="text-secondary-light d-block">@Model.Detail</small>
    </span>
    <small class="text-secondary-light text-capitalize">@Model.State</small>
</li>
