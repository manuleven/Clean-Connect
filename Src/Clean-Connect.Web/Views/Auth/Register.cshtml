@model Clean_Connect.Application.Command.ApplicationUserCommand.RegisterUserCommand

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-container">

    <!-- LEFT SIDE -->
    <div class="auth-left">

        <div class="overlay"></div>

        <div class="left-content">

            <div class="brand">
                <i class="fa-solid fa-broom"></i>
                <h1>Clean Connect</h1>
            </div>

            <h2>Join Clean Connect Today</h2>

            <p>
                Register as a client looking for trusted cleaning
                professionals or become a worker and grow your business.
            </p>

        </div>

    </div>

    <!-- RIGHT SIDE -->

    <div class="auth-right">

        <div class="login-card">

            <div class="text-center mb-4">

                <h2>Create Account</h2>

                <p class="text-muted">
                    Fill in the details below
                </p>

            </div>

            <form asp-action="Register"
                  asp-controller="Auth"
                  method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <!-- Email -->

                <div class="mb-3">

                    <label asp-for="Email" class="form-label"></label>

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Enter your email" />

                    <span asp-validation-for="Email"
                          class="text-danger"></span>

                </div>

                <!-- Password -->

                <div class="mb-4">

                    <label asp-for="Password" class="form-label"></label>

                    <div class="input-group">

                        <input asp-for="Password"
                               id="password"
                               type="password"
                               class="form-control"
                               placeholder="Create a password" />

                        <button class="btn btn-outline-secondary"
                                type="button"
                                id="togglePassword">

                            <i class="fa-solid fa-eye"></i>

                        </button>

                    </div>

                    <span asp-validation-for="Password"
                          class="text-danger"></span>

                </div>

                <!-- Role -->

                <div class="mb-4">

                    <label class="form-label fw-bold">
                        Choose Your Account Type
                    </label>

                    <input asp-for="Role"
                           type="hidden"
                           id="SelectedRole" />

                    <div class="row g-3">

                        <div class="col-md-6">

                            <div class="role-card"
                                 data-role="Client">

                                <i class="fa-solid fa-user role-icon"></i>

                                <h5>Client</h5>

                                <p>
                                    Hire trusted cleaners.
                                </p>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="role-card"
                                 data-role="Worker">

                                <i class="fa-solid fa-broom role-icon"></i>

                                <h5>Worker</h5>

                                <p>
                                    Find cleaning jobs.
                                </p>

                            </div>

                        </div>

                    </div>

                    <span asp-validation-for="Role"
                          class="text-danger"></span>

                </div>

                <button type="submit"
                        class="btn btn-success login-btn w-100">

                    Create Account

                </button>

                <div class="text-center mt-4">

                    Already have an account?

                    <a asp-action="Login">
                        Login
                    </a>

                </div>

            </form>
        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

  

}